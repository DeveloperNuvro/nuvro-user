# Backend API base (no trailing slash). Required when frontend and API are on different origins — needed for WhatsApp voice / Unipile audio playback and media proxy.
# Dev: if the API is exposed via ngrok, point the SPA at the same public origin, e.g.
# VITE_API_BASE_URL=https://YOUR-SUBDOMAIN.ngrok-free.dev
VITE_API_BASE_URL=http://localhost:7575
